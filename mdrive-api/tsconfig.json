{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",

    "declaration": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@mdrive/shared": ["../packages/shared/src/index.ts"]
    }
  },
  "include": ["src", "api", "../packages/shared/src"],
  "exclude": ["node_modules", "dist"]
}
